# Copie para .env e preencha. NUNCA versione o .env real.

# Conexão com o banco (Supabase / Postgres) — use o pooler na porta 6543
DATABASE_URL="postgresql://USUARIO:SENHA@HOST:6543/postgres"

# Segredo usado para assinar os tokens JWT. Gere um valor longo e aleatório, ex.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET="troque-por-um-valor-aleatorio-longo"

# (Opcional) Duração do token de login, em minutos. Padrão: 60
JWT_EXPIRATION_MINUTES=60

# (Opcional) Origens permitidas no CORS, separadas por vírgula. Padrão: "*" (tudo).
# Em produção, restrinja: CORS_ORIGINS="https://app.ibk.org.br"
CORS_ORIGINS=*

# (Opcional) Permite o seed automático do admin@admin.com/admin123 num banco vazio.
# Mantenha 0 em produção; use 1 só para criar o primeiro admin, depois volte para 0.
ALLOW_ADMIN_SEED=0
